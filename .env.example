# Anseropolis 環境設定
# 複製此檔為 .env，填入你的路徑

# LLM Server（llama-server，OpenAI 相容 API）
ANSEROPOLIS_LLM_URL=http://localhost:8080/v1/chat/completions
# 模型名稱（llama-server 的 model 參數，可任意填）
ANSEROPOLIS_LLM_MODEL=ministral

# 推薦模型（無政治審查，中文佳）：
#   首選：Ministral-3-3B-Instruct-2512-Q8_0.gguf（3.4GB，RAM ~4GB）
#   備選：Ministral-3-8B-Reasoning-2512-Q8_0.gguf（8.4GB，RAM ~9.5GB）
#   來源：https://huggingface.co/mistralai/Ministral-3-3B-Instruct-2512-GGUF
#
# 啟動：
#   llama-server -m /path/to/Ministral-3-3B-Instruct-2512-Q8_0.gguf -ngl 99 --port 8080 -c 4096

# CKIP 斷詞模型（選配，不設則用 ckip-transformers 或 jieba）
# 使用 ckip_mlx（MLX 後端 BERT），非官方 ckip-transformers
# 模型目錄需含 ws/, pos/, ner/ 子目錄
# 來源：https://github.com/pf-lin/ckip_mlx
ANSEROPOLIS_CKIP_DIR=
# ckip_batch.py 的完整路徑（含 CKIPBatchProcessor 類別）
ANSEROPOLIS_CKIP_BATCH_PY=

# Qwen3-VL-Embedding-2B（選配，不設則 match 改用關鍵字比對）
# sentence-transformers 格式，2048 維，約 4GB
ANSEROPOLIS_EMBED_DIR=

# SearXNG 自架搜尋引擎（選配，不設則用 DuckDuckGo）
ANSEROPOLIS_SEARXNG_URL=
